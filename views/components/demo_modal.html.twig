{% if env('APP_DEMO') == 'true' or env('APP_DEMO') == true %}
<div id="demo-modal" class="fixed inset-0 z-[9999] items-center justify-center hidden overflow-x-hidden overflow-y-auto outline-none focus:outline-none">
    <!-- Overlay with elegant blur -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-500"></div>
    
    <!-- Modal Content -->
    <div class="relative bg-white rounded-xl shadow-[0_30px_60px_-12px_rgba(0,0,0,0.25)] max-w-lg w-full mx-4 overflow-hidden transform transition-all duration-500 scale-95 opacity-0 border border-gray-100" id="demo-modal-content">
        <!-- Premium Accent bar -->
        <div class="h-1.5 w-full bg-primary"></div>

        <div class="p-8 sm:p-12">
            <h3 class="text-3xl font-bold text-center text-gray-900 mb-3 tracking-tight">
                Mode Démonstration
            </h3>
            <p class="text-center text-gray-500 mb-10 text-lg leading-relaxed max-w-sm mx-auto">
                Bienvenue sur <span class="text-primary font-bold">l'Hôtel Neptune</span>. Explorez le site avec ces comptes de test.
            </p>
            
            <div class="space-y-4">
                <!-- Admin Account -->
                <div class="group p-6 bg-gray-50 rounded-2xl border border-transparent hover:border-primary/20 transition-all duration-300">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center">
                            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center mr-4">
                                <i class="icon-shield-check text-xl text-primary"></i>
                            </div>
                            <span class="font-bold text-gray-900 text-sm uppercase tracking-widest">Administrateur</span>
                        </div>
                        <span class="px-2.5 py-1 bg-primary text-white text-[10px] font-black rounded-lg uppercase tracking-wider">Compte Administrateur</span>
                    </div>
                    <div class="grid grid-cols-1 gap-2">
                        <div class="flex justify-between items-center p-2 rounded-lg hover:bg-white transition-colors">
                            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-wider">Email</span>
                            <span class="text-sm font-medium text-gray-700 select-all cursor-copy">admin@demo.fr</span>
                        </div>
                        <div class="flex justify-between items-center p-2 rounded-lg hover:bg-white transition-colors">
                            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-wider">Mot de passe</span>
                            <span class="text-sm font-medium text-gray-700 select-all cursor-copy">admin</span>
                        </div>
                    </div>
                </div>
                
                <!-- User Account -->
                <div class="group p-6 bg-gray-50 rounded-2xl border border-transparent hover:border-gray-200 transition-all duration-300">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center">
                            <div class="w-10 h-10 bg-gray-200 rounded-xl flex items-center justify-center mr-4">
                                <i class="icon-user text-xl text-gray-600"></i>
                            </div>
                            <span class="font-bold text-gray-900 text-sm uppercase tracking-widest">Client Démo</span>
                        </div>
                        <span class="px-2.5 py-1 bg-gray-200 text-gray-600 text-[10px] font-black rounded-lg uppercase tracking-wider">Compte Utilisateur</span>
                    </div>
                    <div class="grid grid-cols-1 gap-2">
                        <div class="flex justify-between items-center p-2 rounded-lg hover:bg-white transition-colors">
                            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-wider">Email</span>
                            <span class="text-sm font-medium text-gray-700 select-all cursor-copy">jean.dupont@demo.fr</span>
                        </div>
                        <div class="flex justify-between items-center p-2 rounded-lg hover:bg-white transition-colors">
                            <span class="text-[11px] text-gray-400 font-bold uppercase tracking-wider">Mot de passe</span>
                            <span class="text-sm font-medium text-gray-700 select-all cursor-copy">jean.dupont</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-10">
                <button id="close-demo-modal" class="group relative w-full overflow-hidden rounded-2xl bg-primary py-5 px-8 font-bold text-white transition-all shadow-lg hover:shadow-primary/30 hover:-translate-y-0.5 active:scale-[0.98]">
                    <span class="relative flex items-center justify-center text-lg">
                        Accéder à la démo
                        <i class="icon-arrow-right text-xl ml-3 group-hover:translate-x-1 transition-transform"></i>
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
#demo-modal-content.show {
    transform: scale(1);
    opacity: 1;
}
.text-primary { color: var(--color-primary, #16C7CD); }
.bg-primary { background-color: var(--color-primary, #16C7CD); }
.bg-primary\/10 { background-color: rgba(22, 199, 205, 0.1); }
.hover\:border-primary\/20:hover { border-color: rgba(22, 199, 205, 0.2); }
</style>
{% endif %}


